# Prism — environment variable catalog (copy to .env and fill in). NEVER commit the real .env.
# Backend binds Azure__* / Prism__* into strongly-typed options (see architecturalPlan/05).

# ── Azure AI Foundry ─────────────────────────────────────────────────────────
Azure__AiProjectEndpoint=
Azure__AiProjectName=

# ── Azure OpenAI (CopilotKit Node sidecar) ───────────────────────────────────
Azure__OpenAiEndpoint=
Azure__OpenAiApiVersion=2024-12-01-preview

# ── Azure Cosmos DB ──────────────────────────────────────────────────────────
Azure__CosmosEndpoint=
Azure__CosmosDatabase=prism

# ── Azure AI Search ──────────────────────────────────────────────────────────
Azure__SearchEndpoint=
Azure__SearchIndex=prism-ratings

# ── Azure OpenAI embeddings (tools/SeedData corpus vectorization, pkg 03) ─────
# Reuses Azure__OpenAiEndpoint above. Auth is DefaultAzureCredential (az login) — NO keys.
# The deployment name must match a real text-embedding-3-small deployment on the account, and the
# dimensions must match the index vector field + query vectorizer (HACKATHON-FINDINGS §6).
Azure__EmbeddingDeployment=text-embedding-3-small
Azure__EmbeddingModel=text-embedding-3-small
Azure__EmbeddingDimensions=1536

# ── Prism: real data connectors ──────────────────────────────────────────────
Prism__FredApiKey=
Prism__SecUserAgent=prism-hack contact@example.com

# ── Prism: LIVE rating-provider MCP servers (Morningstar + Moody's) ───────────
# Both are hosted REMOTE MCP servers (Streamable HTTP) authenticated with OAuth 2.1
# (authorization_code + PKCE + refresh_token). There is NO headless grant: a ONE-TIME interactive
# browser sign-in (Phase-0 discovery CLI) captures a refresh token that the backend then reuses.
# Fill ClientId/ClientSecret from your provider onboarding (pre-registered client); the RedirectUri
# must be allow-listed for that client. Leave ClientId blank / Enabled=false to stay on the synthetic
# corpus. NEVER commit a real ClientSecret — this .env.example is committed; your .env is git-ignored.
Prism__Providers__Morningstar__Enabled=false
Prism__Providers__Morningstar__McpUrl=https://mcp.morningstar.com/mcp
Prism__Providers__Morningstar__ClientId=
Prism__Providers__Morningstar__ClientSecret=
Prism__Providers__Morningstar__RedirectUri=http://localhost:8765/callback

Prism__Providers__Moodys__Enabled=false
Prism__Providers__Moodys__McpUrl=https://api.moodys.com/genai-ready-data/m1/mcp
Prism__Providers__Moodys__ClientId=
Prism__Providers__Moodys__ClientSecret=
Prism__Providers__Moodys__RedirectUri=http://localhost:8765/callback

# (Superseded) The old REST placeholders below are kept only for the nullable PrismOptions.ProviderApis
# seam; the live path above uses MCP + OAuth, not a REST BaseUrl/ApiKey.
# Prism__ProviderApis__MoodysApi__BaseUrl=
# Prism__ProviderApis__MorningstarApi__BaseUrl=

# ── Prism: model selection per agent ─────────────────────────────────────────
# These must be REAL deployment names on your Foundry account. The sample below uses gpt-5.4
# (the only model deployed for this POC). Point any role at a cheaper deployment (e.g. gpt-4.1-mini)
# once it exists — an unknown deployment name fails loud with a DeploymentNotFound 404.
Prism__Models__Orchestrator=gpt-5.4
Prism__Models__Provider=gpt-5.4
Prism__Models__Fundamentals=gpt-5.4
Prism__Models__RedFlag=gpt-5.4

# ── CopilotKit Node runtime (copilot-runtime/) ───────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
API_BASE_URL=http://localhost:8000
PRISM_AGUI_URL=http://localhost:8000/prism

# ── Observability ────────────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
