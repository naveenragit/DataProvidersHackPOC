# C# API — Azure configuration (bind via the AZURE__ prefix).
# Fill every value with a REAL Azure resource. Missing required values fail at startup.

# Azure AI Foundry
AZURE__AiProjectEndpoint=https://<hub>.services.ai.azure.com/api/projects/<project>
AZURE__AiProjectName=<project-name>

# Azure OpenAI (used by the CopilotKit Node sidecar)
AZURE__OpenAiEndpoint=https://<name>.openai.azure.com/
AZURE__OpenAiApiVersion=2024-12-01-preview

# Azure Cosmos DB
AZURE__CosmosEndpoint=https://<name>.documents.azure.com:443/
AZURE__CosmosDatabase=<database-name>

# Azure AI Search
AZURE__SearchEndpoint=https://<name>.search.windows.net
AZURE__SearchIndex=<index-name>

# Azure AI Content Safety
AZURE__ContentSafetyEndpoint=https://<name>.cognitiveservices.azure.com/

# Azure Monitor
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Identity (local dev / service principal fallback only — prefer `az login` / managed identity)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
