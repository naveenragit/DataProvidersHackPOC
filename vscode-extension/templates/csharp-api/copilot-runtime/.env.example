# CopilotKit Node runtime sidecar configuration.
PORT=4000

# Where the C# ASP.NET Core API is reachable.
API_BASE_URL=http://localhost:8000

# Azure OpenAI (server-side only — never exposed to the browser).
AZURE_OPENAI_ENDPOINT=https://<name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<chat-deployment-name>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Prefer managed identity / az login where possible. Key is a local-dev fallback only.
AZURE_OPENAI_API_KEY=
